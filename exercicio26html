<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Alistamento Militar</title>
</head>
<body>
  <h2>Alistamento Militar</h2>

  <label for="anoNascimento">Ano de nascimento: </label>
  <input type="number" id="anoNascimento"><br><br>

  <button onclick="verificar()">Verificar</button>

  <h3>Resultado:</h3>
  <p id="resultado"></p>

  <script>
    function verificar() {
      const anoAtual = 2025;
      let nascimento = parseInt(document.getElementById("anoNascimento").value);
      let idade = anoAtual - nascimento;
      let mensagem = "Você tem " + idade + " anos em " + anoAtual + ".<br>";

      if (idade < 18) {
        let faltam = 18 - idade;
        mensagem += "Ainda vai se alistar. Faltam " + faltam + " anos.";
      } else if (idade === 18) {
        mensagem += "Você deve se alistar este ano!";
      } else {
        let atraso = idade - 18;
        mensagem += "Já deveria ter se alistado há " + atraso + " anos.";
      }

      document.getElementById("resultado").innerHTML = mensagem;
    }
  </script>
</body>
</html>