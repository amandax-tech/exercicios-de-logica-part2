<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Verificação de Triângulo</title>
</head>
<body>
  <h2>É um Triângulo?</h2>

  <label for="lado1">Lado 1: </label>
  <input type="number" id="lado1" step="0.1"><br><br>

  <label for="lado2">Lado 2: </label>
  <input type="number" id="lado2" step="0.1"><br><br>

  <label for="lado3">Lado 3: </label>
  <input type="number" id="lado3" step="0.1"><br><br>

  <button onclick="verificar()">Verificar</button>

  <h3>Resultado:</h3>
  <p id="resultado"></p>

  <script>
    function verificar() {
      let a = parseFloat(document.getElementById("lado1").value);
      let b = parseFloat(document.getElementById("lado2").value);
      let c = parseFloat(document.getElementById("lado3").value);

      if ((a + b > c) && (a + c > b) && (b + c > a)) {
        document.getElementById("resultado").innerHTML =
          "As retas PODEM formar um triângulo.";
      } else {
        document.getElementById("resultado").innerHTML =
          "As retas NÃO podem formar um triângulo.";
      }
    }
  </script>
</body>
</html>