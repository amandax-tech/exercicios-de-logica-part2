<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Ano Bissexto</title>
</head>
<body>
  <h2>Verificação de Ano Bissexto</h2>

  <label for="ano">Informe o ano: </label>
  <input type="number" id="ano"><br><br>

  <button onclick="verificar()">Verificar</button>

  <h3>Resultado:</h3>
  <p id="resultado"></p>

  <script>
    function verificar() {
      let ano = parseInt(document.getElementById("ano").value);
      let bissexto = false;

      if ((ano % 4 === 0 && ano % 100 !== 0) || (ano % 400 === 0)) {
        bissexto = true;
      }

      if (bissexto) {
        document.getElementById("resultado").innerHTML =
          "O ano " + ano + " é bissexto.";
      } else {
        document.getElementById("resultado").innerHTML =
          "O ano " + ano + " NÃO é bissexto.";
      }
    }
  </script>
</body>
</html>