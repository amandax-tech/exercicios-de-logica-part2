<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Pedra, Papel e Tesoura</title>
</head>
<body>
  <h2>Pedra, Papel e Tesoura</h2>

  <label for="jogador1">Jogada Jogador 1 (1-Pedra, 2-Papel, 3-Tesoura): </label>
  <input type="number" id="jogador1" min="1" max="3"><br><br>

  <label for="jogador2">Jogada Jogador 2 (1-Pedra, 2-Papel, 3-Tesoura): </label>
  <input type="number" id="jogador2" min="1" max="3"><br><br>

  <button onclick="verificar()">Verificar</button>

  <h3>Resultado:</h3>
  <p id="resultado"></p>

  <script>
    function verificar() {
      let j1 = parseInt(document.getElementById("jogador1").value);
      let j2 = parseInt(document.getElementById("jogador2").value);
      let resultado = "";

      if (j1 === j2) {
        resultado = "Empate!";
      } else if (
        (j1 === 1 && j2 === 3) ||
        (j1 === 2 && j2 === 1) ||
        (j1 === 3 && j2 === 2)
      ) {
        resultado = "Jogador 1 VENCEU!";
      } else {
        resultado = "Jogador 2 VENCEU!";
      }

      document.getElementById("resultado").innerHTML = resultado;
    }
  </script>
</body>
</html>