<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Preço da Passagem</title>
</head>
<body>
  <h2>Preço da Passagem de Ônibus</h2>

  <label for="distancia">Distância (Km): </label>
  <input type="number" id="distancia" step="0.1"><br><br>

  <button onclick="calcular()">Calcular</button>

  <h3>Resultado:</h3>
  <p id="resultado"></p>

  <script>
    function calcular() {
      let km = parseFloat(document.getElementById("distancia").value);
      let preco = 0;

      if (km <= 200) {
        preco = km * 0.50;
      } else {
        preco = km * 0.45;
      }

      document.getElementById("resultado").innerHTML =
        "O preço da passagem é: R$ " + preco.toFixed(2);
    }
  </script>
</body>
</html>